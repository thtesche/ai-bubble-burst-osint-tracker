# AI Bubble Burst OSINT Tracker - Konfiguration
# Kopiere diese Datei zu .env und passe die Werte an.

# --- Search Query ---
# Wonach sucht die Pipeline?
SEARCH_QUERY="AI market bubble burst risk analysis 2025 2026"

# --- Limit ---
# Anzahl der News-Artikel, die pro Suchlauf analysiert werden.
PIPELINE_LIMIT=5

# --- Market Tickers ---
# Komma-separierte Liste der zu überwachenden Aktien-Ticker.
MARKET_TICKERS=MSFT,GOOGL,AMZN,META,NVDA,AMD,ASML,AVGO,MU,DELL,SMCI,HPE

# --- Telegram Delivery ---
# Bot-Token und Chat-ID für die Zustellung des Reports über Telegram.
# Hinterlasse diese Felder leer, wenn du keinen Telegram-Versand benötigst.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- LLM Inference (optional) ---
# Konfiguration für LLM-basierte Bubble-Risk-Analyse nach der Pipeline.
# Wenn nicht gesetzt, wird die LLM-Analyse übersprungen.

# API-Key für die OpenAI-compatible API (z.B. OpenAI, Firecrawl Atlantis, Ollama)
LLM_API_KEY=

# Base URL der OpenAI-compatible API (standard OpenAI, oder lokale Instanz)
# Beispiel für lokales Firecrawl/Atlantis: http://localhost:3002/v1
# Beispiel für Ollama: http://localhost:11434/v1
LLM_API_BASE_URL=https://api.openai.com/v1

# Modellname (z.B. gpt-4o-mini, gpt-4o, llama-3.1-405b, etc.)
LLM_MODEL=gpt-4o-mini
